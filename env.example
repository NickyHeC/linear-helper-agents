# Dedalus API Key (get from https://dedalus.dev/dashboard/api-keys)
DEDALUS_API_KEY=dsk-live-your-key-here

# Linear API Key (get from Linear Settings > Account > API > Personal API keys)
LINEAR_API_KEY=lin_api_your-key-here

# Linear MCP server slug on Dedalus marketplace (required)
LINEAR_MCP_SERVER=your-username/linear-mcp

# LLM model for analysis (Dedalus model routing format)
MODEL=anthropic/claude-sonnet-4-20250514

# Agent timeout in seconds (default 600 = 10 minutes)
AGENT_TIMEOUT=600

# Team name to analyze (default: Engineering)
# LINEAR_TEAM_NAME=Engineering

# Path to a previously generated neglect report (used by revamp/categorize scripts)
# REPORT_PATH=neglect_report.md

# --- categorize_issues.py specific (all optional) ---
# Comma-separated issue IDs that need manual action (no Linear changes)
# ACTION_NEEDED_IDS=TEAM-1,TEAM-2,TEAM-3
# Comma-separated issue IDs to move to a project
# MOVE_TO_PROJECT_IDS=TEAM-4,TEAM-5
# Target project name for moved issues
# MOVE_TO_PROJECT_NAME=My Project
